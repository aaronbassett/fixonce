  },
  "dependencies": {
    "@fixonce/pipeline": "workspace:*",
    "@fixonce/shared": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "~5.7.0"
  }
}
